{
  "name": "oracle-studio",
  "version": "0.1.0",
  "type": "module",
  "description": "React dashboard for oracle-v2 API",
  "bin": {
    "oracle-studio": "./bin/serve.ts"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Soul-Brews-Studio/oracle-studio.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
